<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://www.flowable.org/processdef">

  <!--
    流程：流程中心综合测评
    ProcessDefinitionKey : process_center_comprehensive_evaluation
    BusinessType         : process_center_comprehensive_evaluation

    场景：综合事项审批，用于流程中心能力收官测评。

    逐段选人模型：
      1. 发起人只选择第一段处理人：法务、财务、技术、汇总确认人。
      2. 汇总确认人选择会签专家。
      3. 会签专家全部完成后，当前会签节点选择或签领导。
      4. 或签领导任一人完成后，当前或签节点选择归档确认人。
      5. 归档确认后进入最终 HttpTask，通知业务系统流程已完成。

    覆盖能力：
      单人节点、排他网关、并行网关、会签、或签、最终完成回调 HttpTask。
  -->
  <process id="process_center_comprehensive_evaluation"
           name="流程中心综合测评"
           isExecutable="true">

    <startEvent id="start_event" name="开始"/>

    <sequenceFlow id="flow_start_to_ut01"
                  sourceRef="start_event"
                  targetRef="ut01_starter_submit"/>

    <userTask id="ut01_starter_submit"
              name="发起人提交"
              flowable:assignee="${starterAssignee}">
      <documentation>
        发起人填写综合事项，并选择第一段处理人。
        slots: legal_reviewer、finance_reviewer、tech_reviewer、summary_confirmer
      </documentation>
      <extensionElements>
        <flowable:field name="nodeSemantic" stringValue="PC_EVAL_STARTER_SUBMIT"/>
        <flowable:field name="pageCode" stringValue="https://httpbin.org/get?node=pc_eval_starter_submit"/>
        <flowable:field name="isConvergencePoint" stringValue="false"/>
      </extensionElements>
    </userTask>

    <sequenceFlow id="flow_ut01_to_eg01"
                  sourceRef="ut01_starter_submit"
                  targetRef="eg01_need_legal_review"/>

    <exclusiveGateway id="eg01_need_legal_review"
                      name="是否需要法务复核"
                      default="flow_eg01_to_eg02"/>

    <sequenceFlow id="flow_eg01_to_ut02"
                  sourceRef="eg01_need_legal_review"
                  targetRef="ut02_legal_review">
      <conditionExpression xsi:type="tFormalExpression"><![CDATA[${needLegalReview == true}]]></conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow_eg01_to_eg02"
                  sourceRef="eg01_need_legal_review"
                  targetRef="eg02_after_legal_merge"/>

    <userTask id="ut02_legal_review"
              name="法务复核"
              flowable:assignee="${legalReviewerAssignee}">
      <documentation>
        法务风险复核。此节点不选择下一段人员。
      </documentation>
      <extensionElements>
        <flowable:field name="nodeSemantic" stringValue="PC_EVAL_LEGAL_REVIEW"/>
        <flowable:field name="pageCode" stringValue="https://httpbin.org/get?node=pc_eval_legal_review"/>
        <flowable:field name="isConvergencePoint" stringValue="false"/>
      </extensionElements>
    </userTask>

    <sequenceFlow id="flow_ut02_to_eg02"
                  sourceRef="ut02_legal_review"
                  targetRef="eg02_after_legal_merge"/>

    <exclusiveGateway id="eg02_after_legal_merge"
                      name="法务路径汇合"/>

    <sequenceFlow id="flow_eg02_to_pg01"
                  sourceRef="eg02_after_legal_merge"
                  targetRef="pg01_parallel_split"/>

    <parallelGateway id="pg01_parallel_split" name="并行审核拆分"/>

    <sequenceFlow id="flow_pg01_to_ut03"
                  sourceRef="pg01_parallel_split"
                  targetRef="ut03_finance_review"/>
    <sequenceFlow id="flow_pg01_to_ut04"
                  sourceRef="pg01_parallel_split"
                  targetRef="ut04_tech_review"/>

    <userTask id="ut03_finance_review"
              name="财务审核"
              flowable:assignee="${financeReviewerAssignee}">
      <documentation>
        财务可行性审核。此节点不选择下一段人员。
      </documentation>
      <extensionElements>
        <flowable:field name="nodeSemantic" stringValue="PC_EVAL_FINANCE_REVIEW"/>
        <flowable:field name="pageCode" stringValue="https://httpbin.org/get?node=pc_eval_finance_review"/>
        <flowable:field name="isConvergencePoint" stringValue="false"/>
      </extensionElements>
    </userTask>

    <userTask id="ut04_tech_review"
              name="技术审核"
              flowable:assignee="${techReviewerAssignee}">
      <documentation>
        技术可行性审核。此节点不选择下一段人员。
      </documentation>
      <extensionElements>
        <flowable:field name="nodeSemantic" stringValue="PC_EVAL_TECH_REVIEW"/>
        <flowable:field name="pageCode" stringValue="https://httpbin.org/get?node=pc_eval_tech_review"/>
        <flowable:field name="isConvergencePoint" stringValue="false"/>
      </extensionElements>
    </userTask>

    <sequenceFlow id="flow_ut03_to_pg02"
                  sourceRef="ut03_finance_review"
                  targetRef="pg02_parallel_join"/>
    <sequenceFlow id="flow_ut04_to_pg02"
                  sourceRef="ut04_tech_review"
                  targetRef="pg02_parallel_join"/>

    <parallelGateway id="pg02_parallel_join" name="并行审核汇合"/>

    <sequenceFlow id="flow_pg02_to_ut05"
                  sourceRef="pg02_parallel_join"
                  targetRef="ut05_summary_confirm"/>

    <userTask id="ut05_summary_confirm"
              name="汇总确认"
              flowable:assignee="${summaryConfirmerAssignee}">
      <documentation>
        汇总法务、财务、技术审核结果，并选择会签专家。
        slots: committee_members
      </documentation>
      <extensionElements>
        <flowable:field name="nodeSemantic" stringValue="PC_EVAL_SUMMARY_CONFIRM"/>
        <flowable:field name="pageCode" stringValue="https://httpbin.org/get?node=pc_eval_summary_confirm"/>
        <flowable:field name="isConvergencePoint" stringValue="true"/>
      </extensionElements>
    </userTask>

    <sequenceFlow id="flow_ut05_to_ut06"
                  sourceRef="ut05_summary_confirm"
                  targetRef="ut06_committee_countersign"/>

    <userTask id="ut06_committee_countersign"
              name="专家委员会会签"
              flowable:assignee="${committeeAssignee.asText()}">
      <documentation>
        committeeAssigneeList 中每个人生成一个待办。全部专家完成后继续，并在完成当前节点时选择或签领导。
        slots: quick_approvers
      </documentation>
      <extensionElements>
        <flowable:field name="nodeSemantic" stringValue="PC_EVAL_COMMITTEE_COUNTERSIGN"/>
        <flowable:field name="pageCode" stringValue="https://httpbin.org/get?node=pc_eval_committee_countersign"/>
        <flowable:field name="isConvergencePoint" stringValue="false"/>
      </extensionElements>
      <multiInstanceLoopCharacteristics isSequential="false"
                                        flowable:collection="${committeeAssigneeList}"
                                        flowable:elementVariable="committeeAssignee">
        <completionCondition>${nrOfCompletedInstances == nrOfInstances}</completionCondition>
      </multiInstanceLoopCharacteristics>
    </userTask>

    <sequenceFlow id="flow_ut06_to_ut07"
                  sourceRef="ut06_committee_countersign"
                  targetRef="ut07_quick_orsign"/>

    <userTask id="ut07_quick_orsign"
              name="快速决策或签"
              flowable:assignee="${quickApprover.asText()}">
      <documentation>
        quickApproverList 中每个人生成一个待办。任意一名领导通过后继续，并在完成当前节点时选择归档确认人。
        slots: archive_owner
      </documentation>
      <extensionElements>
        <flowable:field name="nodeSemantic" stringValue="PC_EVAL_QUICK_ORSIGN"/>
        <flowable:field name="pageCode" stringValue="https://httpbin.org/get?node=pc_eval_quick_orsign"/>
        <flowable:field name="isConvergencePoint" stringValue="false"/>
      </extensionElements>
      <multiInstanceLoopCharacteristics isSequential="false"
                                        flowable:collection="${quickApproverList}"
                                        flowable:elementVariable="quickApprover">
        <completionCondition>${nrOfCompletedInstances &gt;= 1}</completionCondition>
      </multiInstanceLoopCharacteristics>
    </userTask>

    <sequenceFlow id="flow_ut07_to_ut08"
                  sourceRef="ut07_quick_orsign"
                  targetRef="ut08_archive_confirm"/>

    <userTask id="ut08_archive_confirm"
              name="归档确认"
              flowable:assignee="${archiveAssignee}">
      <documentation>
        单人归档确认，完成后进入最终通知节点。
      </documentation>
      <extensionElements>
        <flowable:field name="nodeSemantic" stringValue="PC_EVAL_ARCHIVE_CONFIRM"/>
        <flowable:field name="pageCode" stringValue="https://httpbin.org/get?node=pc_eval_archive_confirm"/>
        <flowable:field name="isConvergencePoint" stringValue="true"/>
      </extensionElements>
    </userTask>

    <sequenceFlow id="flow_ut08_to_st09"
                  sourceRef="ut08_archive_confirm"
                  targetRef="st09_framework_callback"/>

    <serviceTask id="st09_framework_callback"
                 name="通知业务系统流程已完成"
                 flowable:type="http">
      <documentation>
        框架标准完成回调节点，引擎 POST frameworkCallbackUrl。
        流程中心接收后更新流程状态，并按启动 callback.url 通知业务系统。
      </documentation>
      <extensionElements>
        <flowable:field name="requestMethod">
          <flowable:string>POST</flowable:string>
        </flowable:field>
        <flowable:field name="requestUrl">
          <flowable:expression>${frameworkCallbackUrl}</flowable:expression>
        </flowable:field>
        <flowable:field name="requestHeaders">
          <flowable:string>Content-Type: application/json</flowable:string>
        </flowable:field>
        <flowable:field name="requestBody">
          <flowable:expression>{"processInstanceId":"${execution.processInstanceId}","businessId":"${businessId}","processDefinitionKey":"${processDefinitionKey}"}</flowable:expression>
        </flowable:field>
        <flowable:field name="saveResponseParameters">
          <flowable:string>false</flowable:string>
        </flowable:field>
      </extensionElements>
    </serviceTask>

    <sequenceFlow id="flow_st09_to_end"
                  sourceRef="st09_framework_callback"
                  targetRef="end_event"/>

    <endEvent id="end_event" name="结束"/>

  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_process_center_comprehensive_evaluation">
    <bpmndi:BPMNPlane id="BPMNPlane_process_center_comprehensive_evaluation"
                      bpmnElement="process_center_comprehensive_evaluation">

      <bpmndi:BPMNShape id="shape_start_event" bpmnElement="start_event">
        <omgdc:Bounds x="80" y="200" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_ut01" bpmnElement="ut01_starter_submit">
        <omgdc:Bounds x="160" y="178" width="160" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_eg01" bpmnElement="eg01_need_legal_review" isMarkerVisible="true">
        <omgdc:Bounds x="370" y="193" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_ut02" bpmnElement="ut02_legal_review">
        <omgdc:Bounds x="470" y="78" width="160" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_eg02" bpmnElement="eg02_after_legal_merge" isMarkerVisible="true">
        <omgdc:Bounds x="610" y="193" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_pg01" bpmnElement="pg01_parallel_split" isMarkerVisible="true">
        <omgdc:Bounds x="690" y="193" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_ut03" bpmnElement="ut03_finance_review">
        <omgdc:Bounds x="800" y="110" width="160" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_ut04" bpmnElement="ut04_tech_review">
        <omgdc:Bounds x="800" y="270" width="160" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_pg02" bpmnElement="pg02_parallel_join" isMarkerVisible="true">
        <omgdc:Bounds x="1020" y="193" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_ut05" bpmnElement="ut05_summary_confirm">
        <omgdc:Bounds x="1120" y="178" width="160" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_ut06" bpmnElement="ut06_committee_countersign">
        <omgdc:Bounds x="1340" y="178" width="180" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_ut07" bpmnElement="ut07_quick_orsign">
        <omgdc:Bounds x="1580" y="178" width="180" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_ut08" bpmnElement="ut08_archive_confirm">
        <omgdc:Bounds x="1820" y="178" width="160" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_st09" bpmnElement="st09_framework_callback">
        <omgdc:Bounds x="2040" y="178" width="190" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end_event" bpmnElement="end_event">
        <omgdc:Bounds x="2290" y="200" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="edge_flow_start_to_ut01" bpmnElement="flow_start_to_ut01">
        <omgdi:waypoint x="116" y="218"/>
        <omgdi:waypoint x="160" y="218"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_ut01_to_eg01" bpmnElement="flow_ut01_to_eg01">
        <omgdi:waypoint x="320" y="218"/>
        <omgdi:waypoint x="370" y="218"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_eg01_to_ut02" bpmnElement="flow_eg01_to_ut02">
        <omgdi:waypoint x="395" y="193"/>
        <omgdi:waypoint x="395" y="118"/>
        <omgdi:waypoint x="470" y="118"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_eg01_to_eg02" bpmnElement="flow_eg01_to_eg02">
        <omgdi:waypoint x="420" y="218"/>
        <omgdi:waypoint x="610" y="218"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_ut02_to_eg02" bpmnElement="flow_ut02_to_eg02">
        <omgdi:waypoint x="630" y="118"/>
        <omgdi:waypoint x="635" y="118"/>
        <omgdi:waypoint x="635" y="193"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_eg02_to_pg01" bpmnElement="flow_eg02_to_pg01">
        <omgdi:waypoint x="660" y="218"/>
        <omgdi:waypoint x="690" y="218"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_pg01_to_ut03" bpmnElement="flow_pg01_to_ut03">
        <omgdi:waypoint x="740" y="218"/>
        <omgdi:waypoint x="760" y="150"/>
        <omgdi:waypoint x="800" y="150"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_pg01_to_ut04" bpmnElement="flow_pg01_to_ut04">
        <omgdi:waypoint x="740" y="218"/>
        <omgdi:waypoint x="760" y="310"/>
        <omgdi:waypoint x="800" y="310"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_ut03_to_pg02" bpmnElement="flow_ut03_to_pg02">
        <omgdi:waypoint x="960" y="150"/>
        <omgdi:waypoint x="1045" y="150"/>
        <omgdi:waypoint x="1045" y="193"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_ut04_to_pg02" bpmnElement="flow_ut04_to_pg02">
        <omgdi:waypoint x="960" y="310"/>
        <omgdi:waypoint x="1045" y="310"/>
        <omgdi:waypoint x="1045" y="243"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_pg02_to_ut05" bpmnElement="flow_pg02_to_ut05">
        <omgdi:waypoint x="1070" y="218"/>
        <omgdi:waypoint x="1120" y="218"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_ut05_to_ut06" bpmnElement="flow_ut05_to_ut06">
        <omgdi:waypoint x="1280" y="218"/>
        <omgdi:waypoint x="1340" y="218"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_ut06_to_ut07" bpmnElement="flow_ut06_to_ut07">
        <omgdi:waypoint x="1520" y="218"/>
        <omgdi:waypoint x="1580" y="218"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_ut07_to_ut08" bpmnElement="flow_ut07_to_ut08">
        <omgdi:waypoint x="1760" y="218"/>
        <omgdi:waypoint x="1820" y="218"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_ut08_to_st09" bpmnElement="flow_ut08_to_st09">
        <omgdi:waypoint x="1980" y="218"/>
        <omgdi:waypoint x="2040" y="218"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_st09_to_end" bpmnElement="flow_st09_to_end">
        <omgdi:waypoint x="2230" y="218"/>
        <omgdi:waypoint x="2290" y="218"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
